#!/usr/bin/env bash

SCRIPT_NAME="Copy Original Path"

notify() {
  if command -v notify-send >/dev/null 2>&1; then
    notify-send "$SCRIPT_NAME" "$1"
  fi
}

die() {
  notify "$1"
  printf '%s: %s\n' "$SCRIPT_NAME" "$1" >&2
  exit 1
}

copy_to_clipboard() {
  if command -v xclip >/dev/null 2>&1 && xclip -selection clipboard; then
    return 0
  fi

  if command -v xsel >/dev/null 2>&1 && xsel --clipboard --input; then
    return 0
  fi

  if command -v wl-copy >/dev/null 2>&1 && wl-copy; then
    return 0
  fi

  return 1
}

canonicalize_path() {
  if command -v realpath >/dev/null 2>&1; then
    realpath -- "$1"
  else
    readlink -f -- "$1"
  fi
}

selected_items() {
  # Nautilus may provide selected items either as local paths or as file:// URIs.
  if [ -n "${NAUTILUS_SCRIPT_SELECTED_FILE_PATHS:-}" ]; then
    printf '%s\n' "$NAUTILUS_SCRIPT_SELECTED_FILE_PATHS"
    return 0
  fi

  if [ -n "${NAUTILUS_SCRIPT_SELECTED_URIS:-}" ]; then
    printf '%s\n' "$NAUTILUS_SCRIPT_SELECTED_URIS"
    return 0
  fi

  return 1
}

gio_attr() {
  local item="$1"
  local attr="$2"

  gio info -a "$attr" -- "$item" 2>/dev/null | sed -n "s/^  ${attr}: //p" | head -n 1
}

gio_local_path() {
  gio info -- "$1" 2>/dev/null | sed -n 's/^local path: //p' | head -n 1
}

resolve_target_path() {
  local item="$1"
  local target_path local_path

  if [ -L "$item" ]; then
    canonicalize_path "$item"
    return 0
  fi

  # gio understands both regular paths and file:// URIs, so it is safer than
  # relying only on shell path tests when Nautilus invokes the script.
  target_path="$(gio_attr "$item" "standard::symlink-target")"
  [ -n "$target_path" ] || return 1

  if [[ "$target_path" = /* ]]; then
    canonicalize_path "$target_path"
    return 0
  fi

  local_path="$(gio_local_path "$item")"
  [ -n "$local_path" ] || return 1
  canonicalize_path "$(dirname -- "$local_path")/$target_path"
}

items="$(selected_items | sed '/^$/d')"
[ -n "$items" ] || die "No file or folder selected"

resolved_paths="$(
  while IFS= read -r item; do
    [ -n "$item" ] || continue

    resolve_target_path "$item" || continue
  done <<EOF
$items
EOF
)"

[ -n "$resolved_paths" ] || die "No shortcut files or folders selected"

if ! printf '%s' "$resolved_paths" | copy_to_clipboard; then
  die "Clipboard copy failed. Install or fix xclip, xsel, or wl-copy."
fi

notify "Copied original path(s)"
