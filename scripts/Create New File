#!/usr/bin/env bash

SCRIPT_NAME="Create New File"

notify() {
  if command -v notify-send >/dev/null 2>&1; then
    notify-send "$SCRIPT_NAME" "$1"
  fi
}

die() {
  notify "$1"
  printf '%s: %s\n' "$SCRIPT_NAME" "$1" >&2
  exit 1
}

if ! command -v zenity >/dev/null 2>&1; then
  die "zenity is required to prompt for the new file name"
fi

# Use the first selected item. Nautilus scripts only appear for selections.
selected_path="$(printf '%s\n' "${NAUTILUS_SCRIPT_SELECTED_FILE_PATHS:-}" | sed -n '/./{p;q;}')"
[ -n "$selected_path" ] || die "Select a file or folder first"

# If selection is a file, create inside its parent folder.
target_dir="$selected_path"
[ -d "$target_dir" ] || target_dir="$(dirname -- "$selected_path")"
[ -d "$target_dir" ] || die "Target folder does not exist"

file_name="$(zenity --entry \
  --title='New File' \
  --text='Enter file name:' \
  --width=320)"

[ -n "$file_name" ] || exit 0

file_path="${target_dir}/${file_name}"

if [ -e "$file_path" ]; then
  zenity --error \
    --title='New File' \
    --text="Already exists:\n${file_name}"
  exit 1
fi

if ! touch -- "$file_path"; then
  die "Could not create file"
fi

notify "Created ${file_path}"
