#!/usr/bin/env bash

SCRIPT_NAME="Open in Sublime Text"

notify() {
  if command -v notify-send >/dev/null 2>&1; then
    notify-send "$SCRIPT_NAME" "$1"
  fi
}

die() {
  notify "$1"
  printf '%s: %s\n' "$SCRIPT_NAME" "$1" >&2
  exit 1
}

find_sublime() {
  local candidate

  for candidate in \
    subl \
    /opt/sublime_text/sublime_text \
    /usr/bin/subl \
    /snap/bin/subl
  do
    if command -v "$candidate" >/dev/null 2>&1; then
      command -v "$candidate"
      return 0
    fi

    if [ -x "$candidate" ]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done

  return 1
}

mapfile -t paths < <(printf '%s\n' "${NAUTILUS_SCRIPT_SELECTED_FILE_PATHS:-}" | sed '/^$/d')
[ "${#paths[@]}" -gt 0 ] || die "No file or folder selected"

sublime_cmd="$(find_sublime)" || die "Sublime Text command not found"
"$sublime_cmd" "${paths[@]}" >/dev/null 2>&1 &
